.hud-title {
    color: rgb(240, 240, 255);
    font-size: 24px;
    -unity-font-style: bold;
}

.hud-score {
    color: rgb(255, 215, 80);
    margin-top: 6px;
    margin-bottom: 6px;
}

.hud-button-primary {
    background-color: rgb(40, 100, 210);
    color: rgb(255, 255, 255);
    padding: 8px 14px;
    border-radius: 8px;
}
